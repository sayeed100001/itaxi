# =============================================
# iTaxi - Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# For Vercel deployment, set these in the Vercel dashboard.

# --- Database (Vercel Postgres / Neon / Supabase) ---
# Vercel Postgres automatically sets POSTGRES_URL when you add the integration.
# You can also use DATABASE_URL directly:
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Force PostgreSQL provider (auto-detected from DATABASE_URL but explicit is safer)
DB_PROVIDER=postgres

# --- Server ---
PORT=5000
NODE_ENV=production

# --- Security (REQUIRED - use a strong random string in production) ---
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# --- Optional: Redis (for Socket.IO horizontal scaling & caching) ---
# REDIS_URL=redis://default:password@host:6379

# --- Optional: Stripe (payments) ---
# STRIPE_SECRET_KEY=sk_live_...

# --- Optional: Twilio (SMS/WhatsApp OTP) ---
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Optional: Firebase (push notifications) ---
# FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json

# --- Optional: Email (OTP / notifications) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@itaxi.af

# --- Optional: Routing API Keys ---
# ORS_API_KEY=your_openrouteservice_key
# MAPBOX_ACCESS_TOKEN=pk.eyJ1...

# --- Optional: Demo data seeding ---
# Set to 1 to seed demo users/drivers on first init
# SEED_DEMO_DATA=1

# --- Rate Limiting ---
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=3000
