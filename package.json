{
  "name": "itaxi---premium-ride-hailing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run server:dev\" \"npm run client\"",
    "build": "vite build --mode production",
    "vercel-build": "vite build --mode production",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "test:integration": "node comprehensive-test.cjs",
    "start": "tsx init-db-auto.ts && tsx server.ts",
    "start:mysql": "tsx init-db-mysql.ts && tsx server.ts",
    "start:pg": "tsx init-db-postgres.ts && tsx server.ts",
    "init-db": "tsx init-db-auto.ts",
    "init-db:mysql": "tsx init-db-mysql.ts",
    "init-db:pg": "tsx init-db-postgres.ts",
    "server": "tsx server.ts",
    "server:dev": "tsx watch server.ts",
    "client": "vite"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.1.0",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.7.0",
    "h3-js": "^4.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "1.9.4",
    "lucide-react": "^0.564.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.5",
    "pg": "^8.16.3",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.2",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "5.0.0-rc.2",
    "recharts": "^3.7.0",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.0",
